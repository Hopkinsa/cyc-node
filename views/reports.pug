<!DOCTYPE html>
html(lang="en")
    head
        meta(charset="UTF-8")
        meta(name="viewport", content=
            "width=device-width, initial-scale=1.0")
        title= report.NAME + ' - Complexity Reports'
        link(rel="stylesheet", href="/static/style.css")
    body
        H1 Complexity Reports

        H2= report.NAME

        form(role='form' method='POST')
            button(type="submit" class="button")= 'Generate report'

        if folders.length > 0
            if folders.length > 1
                H3 Compare
                form(role='form' method='POST' action="/reports/compare" target='_blank')
                    select(name="tgt_1")
                        option(value="")= 'Select report'
                        each item in folders
                            option(value=item)= item

                    =' with '

                    select(name="tgt_2")
                        option(value="")= 'Select report'
                        each item in folders
                            option(value=item)= item
                    br
                    br
                    button(type="submit" class="button")= 'Compare reports'

            H3 Reports
            ul
                each item in folders
                    li
                        = item
                        a(href='/reporting/' + report.FOLDER + '/' + item, target='_blank', class="report-link")= 'Full'
                        a(href='/reports/' + idx + '/' + item, target='_blank', class="report-link")= 'Summary'
        else
            p(class="empty")= 'No reports available'

        p
            a(href='/', class="button") Back